<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.0">
  <POU Name="FB_TestHTTP_Trace" Id="{190c0958-5178-4ffa-b77b-c97409f3753d}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_TestHTTP_Trace
VAR_INPUT
	fbClient : REFERENCE TO FB_IotHttpClient;
END_VAR
VAR
	
	fbRequest: FB_IotHttpRequest;
	fbJson: FB_JsonDomParser;
	bSend : BOOL;
	bContinuous : BOOL;
	state : UDINT;
	
	RisingEdge		: R_TRIG;
	
	sJson: STRING(1024);		
	sContent: STRING(1024);
	
	bJsonRes : BOOL;
	jsonDoc    : SJsonValue;
	jsonVal    : SJsonValue;
		
	reqCount : UDINT;		
	invResCount : UDINT := 0;
	invResValCount : UDINT := 0;
	resVal:STRING;
	nResCnt : UDINT;
	nErrCnt1 : UDINT;
	nErrCnt2 : UDINT;
		
	valOkCount: UDINT;	
	
	sUri: STRING(255) := '/posts';
	eRequestType : ETcIotHttpRequestType := ETcIotHttpRequestType.HTTP_TRACE;	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[RisingEdge( CLK:= bSend );
CASE state OF
0:	
	IF fbClient.bConfigured AND (RisingEdge.Q OR bContinuous) THEN 
		IF fbRequest.SendRequest(sUri:=sUri, fbClient:=fbClient, eRequestType:=eRequestType, 0, 0, 0) THEN				
			state := 1;
			reqCount:=reqCount+1;
		END_IF					
	END_IF
1:
	IF NOT fbRequest.bBusy THEN
			IF NOT fbRequest.bError THEN				 
				jsonDoc := fbRequest.GetJsonDomContent(fbJson);
				IF  jsonDoc <> 0 THEN
					bJsonRes := TRUE;
					fbJson.CopyDocument(sJson, SIZEOF(sJson)-1);
				ELSE
					bJsonRes := FALSE;
				END_IF					
				fbRequest.GetContent(pContent:=ADR(sContent), nContentSize:=SIZEOF(sContent), bSetNullTermination:=TRUE);	
				IF fbRequest.nStatusCode >= 200 AND fbRequest.nStatusCode < 300 THEN
					IF bJsonRes THEN													 								
						IF fbJson.IsArray(jsonDoc) AND fbJson.GetArraySize(jsonDoc) > 0 THEN
							jsonVal := fbJson.GetArrayValueByIdx(jsonDoc, 0);
							IF fbJson.HasMember(jsonVal, 'id')  THEN							
								jsonVal := fbJson.FindMember(jsonVal, 'id');
								IF fbJson.GetUint(jsonVal) = 1 THEN
									valOkCount:=valOkCount+1;
								ELSE
									invResValCount:=invResValCount+1;
								END_IF
							ELSE 
								invResCount:=invResCount+1;	
						END_IF
						ELSE 
							invResCount:=invResCount+1;	
						END_IF
					ELSE
						invResCount:=invResCount+1;
					END_IF					
					nResCnt:=nResCnt+1;
				ELSE
					nErrCnt1:=nErrCnt1+1;					
				END_IF				
			ELSE
				nErrCnt2:=nErrCnt2+1;
			END_IF
			state :=0;				
	END_IF  	
END_CASE
fbClient.Execute();

]]></ST>
    </Implementation>
    <LineIds Name="FB_TestHTTP_Trace">
      <LineId Id="99" Count="2" />
